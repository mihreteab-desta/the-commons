<div class="page-container">
    <div class="page-header">
        <h1>Manage Categories</h1>
        <a href="/admin" class="back-link">&larr; Back to Admin</a>
    </div>

    <div class="admin-grid">
        <div class="admin-card">
            <h2>Add New Category</h2>
            <form action="/admin/categories" method="POST" class="category-form">
                <div class="form-group">
                    <label for="name">Name</label>
                    <input type="text" id="name" name="name" required placeholder="Category name">
                </div>
                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea id="description" name="description" rows="2" placeholder="Short description"></textarea>
                </div>
                <div class="form-group">
                    <label for="icon">Icon Name</label>
                    <input type="text" id="icon" name="icon" placeholder="e.g., zap, tool, sun">
                </div>
                <button type="submit" class="btn btn-primary">Add Category</button>
            </form>
        </div>

        <div class="admin-card">
            <h2>Existing Categories</h2>
            <div class="admin-categories-list">
                <% categories.forEach(cat => { %>
                    <div class="admin-category-item">
                        <div class="category-info">
                            <span class="category-name"><%= cat.name %></span>
                            <span class="category-desc"><%= cat.description || 'No description' %></span>
                            <span class="category-count"><%= cat.item_count %> items</span>
                        </div>
                        <form action="/admin/categories/<%= cat.id %>?_method=DELETE" method="POST" class="inline-form" onsubmit="return confirm('Delete this category?')">
                            <button type="submit" class="btn-icon danger" title="Delete">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                            </button>
                        </form>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>
</div>